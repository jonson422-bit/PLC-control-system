# PLC 智能管控系统配置文件示例
# 复制此文件为 .env 并填入实际值

# 飞书应用配置
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_RECEIVE_ID=your_receive_id_here

# PLC 配置（可选，默认值在代码中）
# PLC_IP=192.168.2.1
# PLC_RACK=0
# PLC_SLOT=1

# 服务配置（可选）
# API_PORT=8088

# 后台任务间隔配置（单位：秒）
CONNECTION_MONITOR_INTERVAL=3   # 连接状态检查间隔
DATA_PUSH_INTERVAL=1            # 数据推送间隔
ALARM_MONITOR_INTERVAL=2        # 告警检查间隔
ERROR_RETRY_INTERVAL=5          # 错误重试间隔
DATA_SAVE_INTERVAL=60           # 历史数据保存间隔（每N次推送保存一次）
