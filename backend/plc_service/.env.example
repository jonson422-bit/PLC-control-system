# PLC 智能管控系统配置文件示例
# 复制此文件为 .env 并填入实际值

# ============ 安全认证 ============
# Bearer Token，为空则不启用认证（默认关闭）
# AUTH_TOKEN=

# CORS 跨域白名单，多个用逗号分隔，* 表示允许所有（默认 *）
# CORS_ORIGINS=*

# ============ PLC 连接 ============
# PLC_IP=192.168.2.1
# PLC_RACK=0
# PLC_SLOT=1

# ============ 飞书通知 ============
# FEISHU_APP_ID=your_app_id_here
# FEISHU_APP_SECRET=your_app_secret_here
# FEISHU_RECEIVE_ID=your_receive_id_here

# ============ AI 诊断 (Ollama) ============
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=deepseek-r1:1.5b

# ============ 后台任务间隔（单位：秒） ============
CONNECTION_MONITOR_INTERVAL=3   # 连接状态检查间隔
DATA_PUSH_INTERVAL=1            # 数据推送间隔
ALARM_MONITOR_INTERVAL=2        # 告警检查间隔
ERROR_RETRY_INTERVAL=5          # 错误重试间隔
DATA_SAVE_INTERVAL=60           # 历史数据保存间隔（每N次推送保存一次）

# ============ 数据管理 ============
# DATA_RETENTION_DAYS=30        # 历史数据保留天数
